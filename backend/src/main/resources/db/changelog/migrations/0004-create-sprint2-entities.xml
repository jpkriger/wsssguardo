            <column name="created_at" type="DATETIME">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="DATETIME"/>
            <column name="deleted_at" type="DATETIME"/>
            <column name="created_by" type="VARCHAR(255)"/>
            <column name="last_modified_by" type="VARCHAR(255)"/>
            <column name="deleted_by" type="VARCHAR(255)"/>
            <column name="name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="project_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="VARCHAR(255)"/>
            <column name="consequences" type="VARCHAR(255)"/>
            <column name="occurrence_probability" type="FLOAT"/>
            <column name="impact_probability" type="FLOAT"/>
            <column name="damage_operations" type="VARCHAR(255)"/>
            <column name="damage_individuals" type="VARCHAR(255)"/>
            <column name="damage_other_orgs" type="VARCHAR(255)"/>
            <column name="recommendation" type="VARCHAR(255)"/>
