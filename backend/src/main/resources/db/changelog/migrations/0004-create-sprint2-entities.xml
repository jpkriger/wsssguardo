        </createTable>
    </changeSet>
    <changeSet id="1777077804783-8" author="francisco">
        <createTable tableName="risks">
            <column name="id" type="UUID">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_risks"/>
