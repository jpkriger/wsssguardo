<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-5.0.xsd"
        objectQuotingStrategy="QUOTE_ONLY_RESERVED_WORDS">

    <changeSet id="0005-1" author="wsssguardo">
        <createTable tableName="findings">
            <column name="id" type="UUID">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_findings"/>
            </column>
            <column name="created_at" type="DATETIME">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="DATETIME"/>
            <column name="deleted_at" type="DATETIME"/>
            <column name="created_by" type="VARCHAR(255)"/>
            <column name="last_modified_by" type="VARCHAR(255)"/>
            <column name="deleted_by" type="VARCHAR(255)"/>
            <column name="name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="TEXT"/>
            <column name="numeric_severity" type="INT"/>
            <column name="categorical_severity" type="VARCHAR(255)"/>
            <column name="category" type="VARCHAR(255)"/>
            <column name="reference" type="VARCHAR(255)"/>
            <column name="project_id" type="UUID">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="0005-2" author="wsssguardo">
        <createTable tableName="finding_assets">
            <column name="finding_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="asset_id" type="UUID">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <addPrimaryKey tableName="finding_assets" columnNames="finding_id, asset_id"
                       constraintName="pk_finding_assets"/>
    </changeSet>

    <changeSet id="0005-3" author="wsssguardo">
        <createTable tableName="finding_artifacts">
            <column name="finding_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="artifact_id" type="UUID">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <addPrimaryKey tableName="finding_artifacts" columnNames="finding_id, artifact_id"
                       constraintName="pk_finding_artifacts"/>
    </changeSet>

    <changeSet id="0005-4" author="wsssguardo">
        <addForeignKeyConstraint baseColumnNames="project_id" baseTableName="findings"
                                 constraintName="FK_FINDINGS_ON_PROJECT"
                                 referencedColumnNames="id" referencedTableName="projects"/>
    </changeSet>

    <changeSet id="0005-5" author="wsssguardo">
        <addForeignKeyConstraint baseColumnNames="finding_id" baseTableName="finding_assets"
                                 constraintName="FK_FINDING_ASSETS_ON_FINDING"
                                 referencedColumnNames="id" referencedTableName="findings"/>
    </changeSet>

    <changeSet id="0005-6" author="wsssguardo">
        <addForeignKeyConstraint baseColumnNames="asset_id" baseTableName="finding_assets"
                                 constraintName="FK_FINDING_ASSETS_ON_ASSET"
                                 referencedColumnNames="id" referencedTableName="assets"/>
    </changeSet>

    <changeSet id="0005-7" author="wsssguardo">
        <addForeignKeyConstraint baseColumnNames="finding_id" baseTableName="finding_artifacts"
                                 constraintName="FK_FINDING_ARTIFACTS_ON_FINDING"
                                 referencedColumnNames="id" referencedTableName="findings"/>
    </changeSet>

    <changeSet id="0005-8" author="wsssguardo">
        <addForeignKeyConstraint baseColumnNames="artifact_id" baseTableName="finding_artifacts"
                                 constraintName="FK_FINDING_ARTIFACTS_ON_ARTIFACT"
                                 referencedColumnNames="id" referencedTableName="artifacts"/>
    </changeSet>

</databaseChangeLog>
